# Normalize text files to LF to reduce cross-platform merge churn
* text=auto eol=lf

# Keep Windows command scripts with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ogg binary
*.wav binary
*.mp3 binary
*.ttf binary
*.otf binary
